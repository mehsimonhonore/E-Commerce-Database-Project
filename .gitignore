# ─────────────────────────────────────────────
# Trendora — .gitignore
# Place this file at the project root.
# ─────────────────────────────────────────────


# ── Node.js ───────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml


# ── Environment & Secrets ─────────────────────
# Never commit credentials or API keys
.env
.env.local
.env.development
.env.production
.env.test


# ── PostgreSQL ────────────────────────────────
*.sql.bak
*.dump
*.backup
trendora_backup_*.sql


# ── OS Files ──────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini


# ── Editors & IDEs ────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace


# ── Logs ──────────────────────────────────────
logs/
*.log


# ── Misc ──────────────────────────────────────
*.tmp
*.swp